# Computer Use Tool 配置文件
# 复制此文件为 .env 并填入你的配置

# ================================
# 必需配置
# ================================

# API 密钥（必需）
API_KEY=your_api_key_here

# ================================
# 可选配置
# ================================

# Provider 名称
# PROVIDER=ark

# 模型名称
# MODEL=doubao-seed-1-6-vision-250815

# API 基础 URL
# BASE_URL=http://ark.cn-beijing.volces.com/api/v3

# Provider 私有 JSON 配置，例如 OpenRouter 推荐 headers
# PROVIDER_CONFIG_JSON=

# 温度参数 (0.0-1.0)
# TEMPERATURE=0.0

# 模型思考模式 (enabled/disabled/auto)
# THINKING_MODE=auto

# 模型思考档位 (low/medium/high)
# REASONING_EFFORT=medium

# 坐标空间 (relative/pixel)
# COORDINATE_SPACE=relative

# relative 坐标量程，例如 1 / 100 / 1000
# COORDINATE_SCALE=1000

# 设备插件名称，默认内置 local；可切换为外部 sandbox/远端设备插件
# DEVICE_NAME=local

# 设备插件私有 JSON 配置，例如 {"sandbox_id":"sbx-1"}
# DEVICE_CONFIG_JSON=

# sandbox 设备示例：
# DEVICE_NAME=sandbox
# DEVICE_CONFIG_JSON={...}

# Android ADB 设备示例：
# 先安装 adb，并在启动 agent 前连接好手机
# DEVICE_NAME=android_adb
# DEVICE_CONFIG_JSON={"swipe_settle_seconds":1.0,"app_name_to_package":{"醒图":"com.xt.retouch"}}

# VNC 设备示例：
# 先安装 vncdotool，并配置远程 VNC 连接参数
# DEVICE_NAME=vnc
# DEVICE_CONFIG_JSON={"host":"127.0.0.1","port":5900,"password":"secret"}

# OpenRouter Provider 示例：
# PROVIDER=openrouter
# BASE_URL=https://openrouter.ai/api/v1
# MODEL=openai/gpt-4o-mini
# PROVIDER_CONFIG_JSON={"http_referer":"https://your-app.example","title":"Computer Use Tool"}

# 外部设备插件目录
# DEVICES_DIR=./devices

# 目标显示器编号，0 表示主显示器
# DISPLAY_INDEX=0

# 传给模型的截图宽高，仅支持相同宽高值；例如 1024 表示缩放为 1024x1024
# SCREENSHOT_SIZE=

# 多轮上下文中最多保留的截图数量（包含当前轮）
# MAX_CONTEXT_SCREENSHOTS=5

# 是否注入历史执行反馈 (true/false)
# INCLUDE_EXECUTION_FEEDBACK=false

# 最大执行步数
# MAX_STEPS=100

# 是否使用自然滚动方向；留空时自动检测系统设置
# NATURAL_SCROLL=

# ================================
# 调试日志配置
# ================================

# 是否保存上下文日志 (true/false)
# SAVE_CONTEXT_LOG=true

# 上下文日志目录
# CONTEXT_LOG_DIR=./logs

# ================================
# 技能系统配置
# ================================

# 技能目录路径
# SKILLS_DIR=./skills

# 是否启用技能系统 (true/false)
# ENABLE_SKILLS=true

# 是否允许单次任务模式使用 ask_user (true/false)
# 默认关闭；开启后，单次任务模式也可以在执行中向用户提问
# ENABLE_ASK_USER_FOR_SINGLE_TASK=false
